# ============================================================
# .dockerignore — Keeps build contexts lean on Windows
# ============================================================

# Windows artefacts
Thumbs.db
Desktop.ini
*.lnk
$RECYCLE.BIN/

# Git
.git
.gitattributes
.github

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Node
node_modules/
.npm/

# Secrets — never bake into images
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/

# IDE
.vscode/
.idea/
*.suo
*.user

# Logs
*.log
logs/

# OS
.DS_Store
