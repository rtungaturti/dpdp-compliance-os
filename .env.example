# ============================================================
# DPDP Compliance OS — Environment Variables
# Copy: copy .env.example .env   (Windows CMD)
#       Copy-Item .env.example .env  (PowerShell)
# ============================================================

# Databases
DB_PASSWORD=compliance_secret_changeme
NEO4J_PASSWORD=compliance_secret_changeme

# Object Storage
MINIO_USER=compliance
MINIO_PASSWORD=compliance_secret_changeme

# Kafka KRaft Cluster ID
# Generate: [System.Guid]::NewGuid().ToString("N").Substring(0,22)
KAFKA_CLUSTER_ID=dpdp-compliance-cluster-001

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# MLflow (must match MINIO credentials above)
MLFLOW_S3_ACCESS_KEY=compliance
MLFLOW_S3_SECRET_KEY=compliance_secret_changeme

# Feature flags
DEBUG_MODE=false
LOG_LEVEL=INFO
